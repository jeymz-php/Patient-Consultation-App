<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.patientinformationandonlineconsultationsystem">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PatientInformationAndOnlineConsultationSystem"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".PatientProfileActivity"
            android:exported="false" />
        <!-- Main (Launcher) -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- Doctors List -->
        <activity
            android:name=".DoctorsListActivity"
            android:exported="false" /> <!-- Schedule Consultation -->
        <activity
            android:name=".ScheduleConsultationActivity"
            android:exported="false" /> <!-- Time Selection -->
        <activity
            android:name=".TimeSelectionActivity"
            android:exported="false" /> <!-- Confirmation -->
        <activity
            android:name=".ConfirmationActivity"
            android:exported="false" /> <!-- Patient Info -->
        <activity
            android:name=".PatientInformationActivity"
            android:exported="false" /> <!-- Register -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false" /> <!-- Login -->
        <activity
            android:name=".LoginActivity"
            android:exported="false" />
    </application>

</manifest>