<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="24dp">

    <!-- Success Icon -->
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_check_circle"
        android:layout_gravity="center"
        android:layout_marginTop="40dp" />

    <!-- Success Message -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You are now Scheduled!"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="16dp" />

    <!-- Appointment Details -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F8F8F8"
        android:padding="16dp"
        android:layout_marginTop="24dp">

        <TextView
            android:id="@+id/tvAppointmentDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date: September 15, 2025\nTime: 2:30 PM"
            android:textSize="16sp"
            android:gravity="center"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Important Note -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Please arrive on time and verify your information. Contact us if you need to cancel or reschedule."
        android:textSize="14sp"
        android:textColor="#666666"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:lineSpacingExtra="4dp" />

    <!-- Continue Button -->
    <Button
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Continue"
        android:layout_marginTop="32dp"
        android:background="#E87C00"
        android:textColor="@android:color/white"
        android:textSize="16sp" />

</LinearLayout>