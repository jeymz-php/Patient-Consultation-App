<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    tools:context=".ConsultationFeedActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#E87C00"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Consultation Video"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Remote Video Container -->
    <FrameLayout
        android:id="@+id/doctorVideoContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_above="@id/bottomControls"
        android:background="#000000">

        <!-- Placeholder / overlay for remote video -->
        <TextView
            android:id="@+id/tvRemotePlaceholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Doctor's Video"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:textSize="22sp"
            android:alpha="0.4" />

        <!-- Local Video (floating) -->
        <FrameLayout
            android:id="@+id/localVideoContainer"
            android:layout_width="140dp"
            android:layout_height="180dp"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:background="#222222"
            android:elevation="12dp"
            android:clipToOutline="true"
            android:padding="2dp"
            android:rotationX="0"
            android:outlineProvider="bounds">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Your Video"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:alpha="0.5"
                android:textSize="14sp" />
        </FrameLayout>

    </FrameLayout>

    <!-- Bottom Controls -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#1F1F1F"
        android:elevation="8dp"
        android:padding="12dp"
        android:weightSum="3">

        <!-- Microphone Button -->
        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/btn_circle_orange"
            android:src="@drawable/ic_mic_white"
            android:contentDescription="Mic"
            android:elevation="6dp"
            android:scaleType="centerInside"
            android:layout_margin="8dp" />

        <!-- End Call Button -->
        <ImageButton
            android:id="@+id/btnEndCall"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/btn_circle_red"
            android:src="@drawable/ic_call_end_white"
            android:contentDescription="End Call"
            android:elevation="6dp"
            android:scaleType="centerInside"
            android:layout_margin="8dp" />

        <!-- Camera Button -->
        <ImageButton
            android:id="@+id/btnCamera"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/btn_circle_orange"
            android:src="@drawable/ic_videocam_white"
            android:contentDescription="Camera"
            android:elevation="6dp"
            android:scaleType="centerInside"
            android:layout_margin="8dp" />
    </LinearLayout>

</RelativeLayout>
