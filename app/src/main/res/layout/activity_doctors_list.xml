<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="?attr/actionBarSize"
    android:orientation="vertical">

    <!-- 🔶 Orange Top Rectangle with Logo + Title -->
    <LinearLayout
        android:id="@+id/topRectangle"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="#E87C00">

        <!-- Doctors Logo -->
        <ImageView
            android:id="@+id/logo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_patient"
            android:contentDescription="Doctors Logo"
            android:layout_marginEnd="8dp" />

        <!-- Title Text -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Our Doctors"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:padding="16dp"
            android:gravity="center" />

    </LinearLayout>

    <!-- Search Bar -->
    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Search doctors..."
        android:drawableStart="@android:drawable/ic_menu_search"
        android:padding="12dp"
        android:layout_margin="8dp"
        android:background="@drawable/search_background"
        android:inputType="text" />

    <!-- 📜 Scrollable Doctors List -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="477dp"
        android:layout_weight="1"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/doctorsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Doctor cards will be added dynamically here -->

        </LinearLayout>
    </ScrollView>
</LinearLayout>